{
  "name": "retailink-api",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "start": "tsx src/index.ts",
    "dev": "nodemon --watch src --ext ts --exec tsx src/index.ts",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "postbuild": "cpx \"src/**/*.{env,json,html,css,png,jpg}\" dist",
    "verify": "pnpm run build && pnpm test",
    "prod": "pnpm run build && pnpm start",
    "prod:pm2": "pnpm run build && pm2 start ecosystem.config.cjs",
    "prod:pm2:restart": "pm2 restart retailink-api",
    "prod:pm2:stop": "pm2 stop retailink-api",
    "prod:pm2:logs": "pm2 logs retailink-api",
    "prod:pm2:status": "pm2 status retailink-api"
  },
  "_moduleAliases": {
    "@": "dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@bull-board/ui": "^6.20.6",
    "@google-cloud/storage": "^7.18.0",
    "@prisma/adapter-mariadb": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "axios": "^1.9.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "bullmq": "^5.71.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "firebase": "^12.2.1",
    "firebase-admin": "^12.6.0",
