    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.3.4",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.14.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "redis": "^5.8.2",
    "resend": "^6.6.0",
    "sharp": "^0.34.5",
    "zod": "^4.4.2"
