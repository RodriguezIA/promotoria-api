  client_logs            client_logs[]
  clients                clients[]
  orders                 orders[]
  question_client_logs   question_client_logs[]
  question_logs          question_logs[]
  questions              questions[]
  questions_client       questions_client[]
  store_logs             store_logs[]
  stores                 stores[]
  user_logs              user_logs[]

  @@index([reset_password_token], map: "idx_reset_token")
  @@index([i_rol, i_status], map: "idx_users_rol_status")
}

model folios {
  id_folio        Int      @id @default(autoincrement()) @db.UnsignedInt
  id_client       Int      @db.UnsignedInt
  vc_entity       String   @db.VarChar(30)
  i_current_folio Int      @default(0) @db.UnsignedInt
  dt_register     DateTime @default(now()) @db.Timestamp(0)
  dt_updated      DateTime @default(now()) @updatedAt @db.Timestamp(0)
  client          clients  @relation(fields: [id_client], references: [id_client], map: "fk_folios_client")

  @@unique([id_client, vc_entity], map: "uq_folios_client_entity")
  @@index([id_client], map: "idx_folios_client")
}

model sales_channels {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  name        String
  description String?
  url_image   String?
  is_active   Boolean  @default(true)
  stores      stores[]
}
