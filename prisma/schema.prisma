generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model addresses {
  id                 Int      @id @default(autoincrement()) @db.UnsignedInt
  entity_type        String   @db.VarChar(50)
  entity_id          Int      @db.UnsignedInt
  id_country         Int      @db.UnsignedInt
  id_state           Int      @db.UnsignedInt
  id_city            Int      @db.UnsignedInt
  street             String   @db.VarChar(150)
  ext_number         String   @db.VarChar(20)
  int_number         String?  @db.VarChar(20)
  neighborhood       String?  @db.VarChar(100)
  postal_code        String   @db.VarChar(20)
  address_references String?  @db.Text
  latitude           Decimal? @db.Decimal(10, 8)
  longitude          Decimal? @db.Decimal(11, 8)
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now()) @db.Timestamp(0)
  updated_at         DateTime @default(now()) @db.Timestamp(0)

  country            countries @relation(fields: [id_country], references: [id])
  state              states    @relation(fields: [id_state], references: [id])
  city               cities    @relation(fields: [id_city], references: [id])
}

model cities {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  id_country Int      @db.UnsignedInt
  id_state   Int      @db.UnsignedInt
  name       String   @db.VarChar(100)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @db.Timestamp(0)

  country    countries   @relation(fields: [id_country], references: [id])
  state      states      @relation(fields: [id_state], references: [id])
  addresses  addresses[]
}

