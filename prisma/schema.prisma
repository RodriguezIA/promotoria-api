generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model addresses {
  id                 Int       @id @default(autoincrement()) @db.UnsignedInt
  entity_type        String    @db.VarChar(50)
  entity_id          Int       @db.UnsignedInt
  id_country         Int       @db.UnsignedInt
  id_state           Int       @db.UnsignedInt
  id_city            Int       @db.UnsignedInt
  street             String    @db.VarChar(150)
  ext_number         String    @db.VarChar(20)
  int_number         String?   @db.VarChar(20)
  neighborhood       String?   @db.VarChar(100)
  postal_code        String    @db.VarChar(20)
  address_references String?   @db.Text
  latitude           Decimal?  @db.Decimal(10, 8)
  longitude          Decimal?  @db.Decimal(11, 8)
  is_active          Boolean   @default(true)
  created_at         DateTime  @default(now()) @db.Timestamp(0)
  updated_at         DateTime  @default(now()) @db.Timestamp(0)
  city               cities    @relation(fields: [id_city], references: [id])
  country            countries @relation(fields: [id_country], references: [id])
  state              states    @relation(fields: [id_state], references: [id])

  @@index([id_city], map: "addresses_id_city_fkey")
  @@index([id_country], map: "addresses_id_country_fkey")
  @@index([id_state], map: "addresses_id_state_fkey")
}

model cities {
  id         Int         @id @default(autoincrement()) @db.UnsignedInt
  id_country Int         @db.UnsignedInt
  id_state   Int         @db.UnsignedInt
  name       String      @db.VarChar(100)
  is_active  Boolean     @default(true)
  created_at DateTime    @default(now()) @db.Timestamp(0)
  updated_at DateTime    @default(now()) @db.Timestamp(0)
  addresses  addresses[]
  country    countries   @relation(fields: [id_country], references: [id])
  state      states      @relation(fields: [id_state], references: [id])

  @@index([id_country], map: "cities_id_country_fkey")
  @@index([id_state], map: "cities_id_state_fkey")
}

model client_logs {
  id_cliente_log Int      @id @default(autoincrement()) @db.UnsignedInt
  id_client      Int      @db.UnsignedInt
  id_user        Int      @db.UnsignedInt
  log            String   @db.VarChar(1000)
  i_status       Int      @default(1) @db.TinyInt
  dt_register    DateTime @default(now()) @db.Timestamp(0)
  dt_updated     DateTime @default(now()) @db.Timestamp(0)
  clients        clients  @relation(fields: [id_client], references: [id_client], map: "fk_logs_client")
  users          users    @relation(fields: [id_user], references: [id_user], map: "fk_logs_client_user")

  @@index([id_client], map: "fk_logs_client")
  @@index([id_user], map: "idx_client_logs_user")
}

model clients {
  id_client               Int                @id @default(autoincrement()) @db.UnsignedInt
  id_user                 Int                @db.UnsignedInt
  name                    String?            @db.VarChar(100)
  vc_initialism           String             @db.VarChar(20)
  i_status                Int                @default(1) @db.TinyInt
  dt_register             DateTime           @default(now()) @db.Timestamp(0)
  dt_updated              DateTime           @default(now()) @db.Timestamp(0)
  rfc                     String             @default("") @db.VarChar(15)
  email                   String             @default("") @db.VarChar(255)
  address                 String             @default("") @db.VarChar(255)
  city                    String             @default("") @db.VarChar(255)
  adiccional_notes        String?            @db.Text
  phone                   String             @default("") @db.VarChar(20)
  vc_url_situacion_fiscal String?            @db.VarChar(500)
  client_logs             client_logs[]
  users                   users              @relation(fields: [id_user], references: [id_user], map: "fk_clients_user")
  orders                  orders[]
  products                products[]
  questions_client        questions_client[]
  requests                requests[]
  tasks                   tasks[]
  folios                  folios[]

  @@index([i_status], map: "idx_clients_status")
  @@index([id_user], map: "idx_clients_user")
}

model countries {
  id         Int         @id @default(autoincrement()) @db.UnsignedInt
  name       String      @db.VarChar(100)
  phone_code String      @db.VarChar(10)
  is_active  Boolean     @default(true)
  created_at DateTime    @default(now()) @db.Timestamp(0)
